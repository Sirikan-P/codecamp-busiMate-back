// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  firstName    String
  lastName     String
  addressId    String
  phoneNumber  String
  status       Status        @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  patients     Patient[]
  userAdresses UserAddress[]

  @@map("user")
}

enum Status {
  ACTIVE
  INACTIVE
}

model Driver {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String
  firstName     String    @map("firstname")
  lastname      String    @map("lastname")
  age           Int
  gender        Gender
  phoneNumber   String
  idCard        String
  carRegNo      String    @map("car_reg_no")
  carType       CarType
  hasWheelChair OnHand    @default(NOHAVE)
  hasAssist     OnHand    @default(NOHAVE)
  online        OnLine    @default(OFFLINE)
  status        Status    @default(ACTIVE)
  wallet        Decimal?
  address       String
  lat           Float
  long          Float
  createdAT     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  bookings      Booking[]

  @@map("driver")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CarType {
  SEETS_4
  SEETS_7
  SEETS_9
}

enum OnHand {
  HAVE
  NOHAVE
}

enum OnLine {
  ONLINE
  OFFLINE
}

model Patient {
  id              Int       @id @default(autoincrement())
  firstName       String    @map("firstname")
  lastName        String    @map("lastname")
  age             Int
  gender          Gender
  phoneNumber     String    @map("phone_number")
  healthCondition String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  user            User      @relation(fields: [userId], references: [id])
  userId          Int
  bookings        Booking[]

  @@map("patient")
}

model Booking {
  id                 Int           @id @default(autoincrement())
  needWheelChair     Request       @default(NOT_NEED)
  needAssist         Request       @default(NOT_NEED)
  appointmentDate    String        @map("appointment_date")
  bookingStatus      BookingStatus @default(FIND_DRIVER) @map("booking_status")
  paymentStatus      PaymentStatus @default(IN_PROCESS) @map("payment_status")
  appointmentImage   String?       @map("@appointment_image")
  specialRequirement String?       @map("special_requirement")
  totalPrice         Decimal       @map("total_price")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  patient            Patient       @relation(fields: [patientId], references: [id])
  patientId          Int
  driver             Driver        @relation(fields: [driverId], references: [id])
  driverId           Int
  hospital           Hospital?     @relation(fields: [hospitalId], references: [id])
  hospitalId         Int?
  reviews            Review[]
  reports            Report[]

  @@map("booking")
}

enum BookingStatus {
  FIND_DRIVER
  UP_COMING
  IN_PROCESS
  COMPLETE
}

enum Request {
  NEED
  NOT_NEED
}

enum PaymentStatus {
  IN_PROCESS
  COMPLETE
}

model Hospital {
  id        Int       @id @default(autoincrement())
  name      String
  address   String
  lat       Float
  long      Float
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  bookings  Booking[]

  @@map("hospital")
}

model Review {
  id        Int      @id @default(autoincrement())
  rate      Rate
  message   String?
  booking   Booking? @relation(fields: [bookingId], references: [id])
  bookingId Int?

  @@map("review")
}

enum Rate {
  A
  B
  C
  D
  E
}

model Report {
  id        Int          @id @default(autoincrement())
  type      Source
  status    ReportStatus @default(IN_PROCESS)
  message   String
  image     String?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  booking   Booking?     @relation(fields: [bookingId], references: [id])
  bookingId Int?
  admin     Admin?       @relation(fields: [adminId], references: [id])
  adminId   Int?

  @@map("report")
}

enum Source {
  USER
  DRIVER
}

enum ReportStatus {
  IN_PROCESS
  COMPLETE
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String?
  firstName String?  @map("firstname")
  lastName  String?  @map("lastname")
  password  String
  reports   Report[]

  @@map("admin")
}

model UserAddress {
  id      Int    @id @default(autoincrement())
  address String
  lat     Float
  log     Float
  user    User?  @relation(fields: [userId], references: [id])
  userId  Int?

  @@map("user_address")
}

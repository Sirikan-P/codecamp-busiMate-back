// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  password    String
  firstName   String
  lastName    String
  addressId   String
  phoneNumber String
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("user")
}

enum Status {
  ACTIVE
  INACTIVE
}

model Driver {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String
  firstName     String   @map("firstname")
  lastname      String   @map("lastname")
  age           Int
  gender        Gender
  phoneNumber   String
  idCard        String
  carRegNo      String   @map("car_reg_no")
  carType       CarType
  hasWheelChair OnHand   @default(NOHAVE)
  hasAssist     OnHand   @default(NOHAVE)
  online        OnLine   @default(OFFLINE)
  status        Status   @default(ACTIVE)
  wallet        Decimal?
  address       String
  lat           Float
  long          Float
  createdAT     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("driver")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CarType {
  SEETS_4
  SEETS_7
  SEETS_9
}

enum OnHand {
  HAVE
  NOHAVE
}

enum OnLine {
  ONLINE
  OFFLINE
}

model Patient {
  id              Int      @id @default(autoincrement())
  firstName       String   @map("firstname")
  lastName        String   @map("lastname")
  age             Int
  gender          Gender
  phoneNumber     String   @map("phone_number")
  healthCondition String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("patient")
}

model Booking {
  id                 Int           @id @default(autoincrement())
  needWheelChair     Request       @default(NOT_NEED)
  needAssist         Request       @default(NOT_NEED)
  appointmentDate    String        @map("appointment_date")
  bookingStatus      BookingStatus @default(FIND_DRIVER) @map("booking_status")
  paymentStatus      PaymentStatus @default(IN_PROCESS) @map("payment_status")
  appointmentImage   String?       @map("@appointment_image")
  specialRequirement String?       @map("special_requirement")
  totalPrice         Decimal       @map("total_price")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("booking")
}

enum BookingStatus {
  FIND_DRIVER
  UP_COMING
  IN_PROCESS
  COMPLETE
}

enum Request {
  NEED
  NOT_NEED
}

enum PaymentStatus {
  IN_PROCESS
  COMPLETE
}

model Hospital {
  id        Int      @id @default(autoincrement())
  name      String
  address   String
  lat       Float
  long      Float
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("hospital")
}

model Review {
  id      Int     @id @default(autoincrement())
  rate    Rate
  message String?

  @@map("review")
}

enum Rate {
  A
  B
  C
  D
  E
}

model Report {
  id        Int          @id @default(autoincrement())
  type      Source
  status    ReportStatus @default(IN_PROCESS)
  message   String
  image     String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("report")
}

enum Source {
  USER
  DRIVER
}

enum ReportStatus {
  IN_PROCESS
  COMPLETE
}

model Admin {
  id Int @id @default(autoincrement())
  email String?
  firstName String? @map("firstname")
  lastName String?  @map("lastname")
  password String

  @@map("admin")
}

model UserAddress {
  id Int @id @default(autoincrement())
  address String
  lat Float
  log Float

  @@map("user_address")
}

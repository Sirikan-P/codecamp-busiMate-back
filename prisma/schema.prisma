generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int           @id @default(autoincrement())
  email            String        @unique
  password         String
  firstName        String
  lastName         String
  profileImage     String?
  phoneNumber      String
  status           Status        @default(ACTIVE)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  role             String        @default("user")
  patients         Patient[]
  sentMessages     Message[]     @relation("UserSentMessages")
  receivedMessages Message[]     @relation("UserReceivedMessages")
  UserAddress      UserAddress[]

  @@map("user")
}

model UserAddress {
  id       Int       @id @default(autoincrement())
  address  String?   @default("HOME")
  lat      Decimal?
  long     Decimal?
  status   String?   @default("USE")
  userId   Int       @map("user_id")
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("user_address")
}

model Message {
  id               Int      @id @default(autoincrement())
  senderUserId     Int?
  senderUser       User?    @relation("UserSentMessages", fields: [senderUserId], references: [id])
  senderDriverId   Int?
  senderDriver     Driver?  @relation("DriverSentMessages", fields: [senderDriverId], references: [id])
  receiverUserId   Int?
  receiverUser     User?    @relation("UserReceivedMessages", fields: [receiverUserId], references: [id])
  receiverDriverId Int?
  receiverDriver   Driver?  @relation("DriverReceivedMessages", fields: [receiverDriverId], references: [id])
  bookingId        Int      @unique
  booking          Booking  @relation(fields: [bookingId], references: [id])
  text             String?  @db.Text
  image            String?
  createdAt        DateTime @default(now()) @db.Timestamp(0)
  updatedAt        DateTime @updatedAt @db.Timestamp(0)
}

enum Status {
  ACTIVE
  INACTIVE
}

model Driver {
  id               Int             @id @default(autoincrement())
  email            String          @unique
  password         String
  firstName        String
  lastName         String
  age              Int
  gender           Gender
  phoneNumber      String
  profileImageUrl  String?         @db.VarChar(500)
  Description      String?  
  idCard           String?
  carRegNo         String?         @map("car_reg_no")
  carType          CarType?
  hasWheelChair    OnHand?         @default(NOHAVE)
  hasAssist        OnHand          @default(NOHAVE)
  online           OnLine          @default(OFFLINE)
  status           Status          @default(ACTIVE)
  wallet           Decimal         @default(0.00)
  createdAT        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  role             String          @default("driver")
  bookings         Booking[]
  sentMessages     Message[]       @relation("DriverSentMessages")
  receivedMessages Message[]       @relation("DriverReceivedMessages")
  DriverWallet     DriverWallet[]
  DriverAddress    DriverAddress[]

  @@map("driver")
}

model DriverAddress {
  id       Int       @id @default(autoincrement())
  address  String?   @default("HOME")
  lat      Decimal?
  long     Decimal?
  status   String?   @default("USE")
  driverId Int
  driver   Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("driver_address")
}

model DriverWallet {
  id        Int             @id @default(autoincrement())
  driverId  Int
  driver    Driver          @relation(fields: [driverId], references: [id], onDelete: Cascade)
  amount    Decimal
  type      TransactionType
  createdAt DateTime        @default(now()) @map("created_at")

  @@map("driver_wallet")
}

enum TransactionType {
  INCOME
  OUTCOME
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CarType {
  SEETS_4
  SEETS_7
  SEETS_9
}

enum OnHand {
  HAVE
  NOHAVE
}

enum OnLine {
  ONLINE
  OFFLINE
}

model Patient {
  id              Int       @id @default(autoincrement())
  firstName       String    @map("firstname")
  lastName        String    @map("lastname")
  age             Int
  gender          Gender
  profileImage     String?
  phoneNumber     String    @map("phone_number")
  healthCondition String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  user            User      @relation(fields: [userId], references: [id])
  userId          Int
  bookings        Booking[]

  @@map("patient")
}

model Booking {
  id                 Int            @id @default(autoincrement())
  needWheelChair     Request        @default(NOT_NEED)
  needAssist         Request        @default(NOT_NEED)
  cartype            CarType        @default(SEETS_4)
  appointmentDate    String?         @map("appointment_date")
  bookingStatus      BookingStatus?  @default(FIND_DRIVER) @map("booking_status")
  paymentStatus      String         @default("IN_PROCESS")  @map("payment_status")// IN_PROCESS, COMPLETE, REFUNDED
  paymentIntentId    String?
  appointmentImage   String?        @map("@appointment_image")
  specialRequirement String?        @map("special_requirement")
  totalPrice         Decimal?        @map("total_price")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  patient            Patient        @relation(fields: [patientId], references: [id])
  patientId          Int
  driver             Driver?         @relation(fields: [driverId], references: [id])
  driverId           Int?
  hospital           Hospital?      @relation(fields: [hospitalId], references: [id])
  hospitalId         Int?
  reviews            Review[]
  reports            Report[]
  Message            Message[]
  DriverAddress      DriverAddress? @relation(fields: [driverAddressId], references: [id])
  driverAddressId    Int?
  UserAddress        UserAddress?   @relation(fields: [userAddressId], references: [id])
  userAddressId      Int?

  @@map("booking")
}

enum BookingStatus {
  FIND_DRIVER
  UP_COMING
  IN_PROCESS
  COMPLETE
  CANCEL
}

enum Request {
  NEED
  NOT_NEED
}

model Hospital {
  id        Int       @id @default(autoincrement())
  name      String
  address   String
  lat       Float
  long      Float
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  bookings  Booking[]

  @@map("hospital")
}

model Review {
  id        Int      @id @default(autoincrement())
  rate      Rate
  message   String?
  booking   Booking? @relation(fields: [bookingId], references: [id])
  bookingId Int?

  @@map("review")
}

enum Rate {
  A
  B
  C
  D
  E
}

model Report {
  id        Int          @id @default(autoincrement())
  type      Source
  status    ReportStatus @default(IN_PROCESS)
  topic     String?
  message   String?
  image     String?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  booking   Booking?     @relation(fields: [bookingId], references: [id])
  bookingId Int?
  admin     Admin?       @relation(fields: [adminId], references: [id])
  adminId   Int?

  @@map("report")
}

enum Source {
  USER
  DRIVER
}

enum ReportStatus {
  IN_PROCESS
  COMPLETE
}

model Admin {
  id           Int      @id @default(autoincrement())
  email        String?
  firstName    String?  @map("firstname")
  lastName     String?  @map("lastname")
  password     String
  profileimage String?
  reports      Report[]

  @@map("admin")
}
